    <string name="tools_discover_title">Set to Google Discover</string>
    <string name="tools_discover_desc">Sets the negative screen to Google Discover.</string>
    <string name="tools_disable_title">Disable Assistant Screen</string>
    <string name="tools_disable_desc">Completely disables the negative screen.</string>
    
    <string name="tools_header_system_apps">System Apps</string>
    <string name="tools_sms_title">Activate ColorOS SMS</string>
    <string name="tools_sms_desc">Grants necessary permissions for the ColorOS SMS app.</string>
    <string name="tools_install_sms_title">Install ColorOS SMS</string>
    <string name="tools_install_sms_desc">Installs the embedded ColorOS SMS app module.</string>
    <string name="tools_wechat_fcm_fix_title">Fix WeChat FCM Push</string>
    <string name="tools_wechat_fcm_fix_desc">Deletes stale WeChat FCM registration files, then restarts WeChat until they are regenerated. Requires root.</string>
    <string name="wechat_fcm_fix_running">Fixing WeChat FCM push. This may take about 2 minutes.</string>
    <string name="wechat_fcm_fix_success">WeChat FCM registration files were regenerated successfully.</string>
    <string name="wechat_fcm_fix_failed">WeChat FCM fix failed: %1$s</string>
    
    <string name="system_header_diagnostics">ARB Detector</string>
    <string name="system_arb_status_title">Check ARB Status</string>
    <string name="system_arb_status_desc">Runs the Anti-Rollback detection tool. Requires root.</string>
    <string name="system_header_experimental">Experimental Features</string>
    <string name="system_anti_arb_title">Anti-ARB</string>
    <string name="system_anti_arb_desc">Synchronizes the xbl_config partition to the inactive slot. Use only BEFORE rebooting an OTA.</string>
    <string name="system_widevine_title">Fix Widevine L1 Certification</string>
    <string name="system_widevine_desc">Burns the device attestation keybox into TEE to restore Widevine L1. This is an irreversible operation that modifies TEE permanently.</string>
    
    <string name="anti_arb_dialog_title">Anti-ARB (High Risk)</string>
    <string name="anti_arb_dialog_text">This feature must only be used AFTER an OTA download completes and BEFORE rebooting!\n\nWARNING: No guarantees of availability. Misuse carries an irrecoverable bricking risk!</string>
